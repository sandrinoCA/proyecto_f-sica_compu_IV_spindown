    "def omega_dot(t, y, B, R, c, I0, epsilon, alpha0, betta):\n",
    "    # 'y' es una lista/array, extraemos el primer valor (omega)\n",
    "    omega = y\n",
    "\n",
    "    #Ángulo que depende del tiempo\n",
    "    a = alpha0 + betta * t\n",
    "    k = (2 * (B * R**3)**2) / (3 * c**3)\n",
    "\n",
    "    #P_dip\n",
    "    p_dip = k * (omega**4) * (np.sin(a)**2)\n",
    "    denominador = I0 * omega * (1 + 2 * epsilon * (omega**2))\n",
    "    \n",
    "    f = -p_dip / denominador\n",
    "\n",
    "    return f"
   ]
